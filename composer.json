{
    "name": "invrt/php-cli",
    "description": "An auth-enabled VRT for Drupal and Backdrop web sites and apps (PHP version)",
    "type": "application",
    "license": "MIT",
    "authors": [
        {
            "name": "Ronan Dowling"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/yaml": ">8.0",
        "symfony/console": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.59",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": ["src/invrt.php"],
    "config": {
        "allow-plugins": {}
    }
}
