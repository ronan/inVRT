{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": false,
    "requireUpstream": true,
    "commitMessage": "Release v${version}",
    "tagName": "v${version}",
    "push": false,
    "pushArgs": [
      "--follow-tags"
    ]
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
  },
  "plugins": {
    "@release-it/bumper": {
      "in": "package.json",
      "out": [
        "VERSION.txt",
        "composer.json",
        {
          "file": "src/cli/invrt.php",
          "type": "text/php"
        },
        {
          "file": "README.md",
          "type": "text/markdown"
        }
      ]
    }
  }
}
