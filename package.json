{
  "name": "invrt",
  "version": "1.0.0",
  "description": "An auth-enabled VRT for Drupal and Backdrop web sites and apps",
  "main": "src/run.js",
  "bin": {
    "invrt": "./bin/invrt"
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node 'src/run.js'",
    "crawl": "node src/invrt.js crawl",
    "init": "node src/invrt.js init",
    "reference": "node src/invrt.js reference",
    "self-test": "node src/cli.test.js",
    "install-deps": "sudo npx playwright install-deps && npx playwright install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronan/inVRT.git"
  },
  "keywords": [
    "vrt",
    "test",
    "automation"
  ],
  "author": "Ronan Dowling",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ronan/inVRT/issues"
  },
  "homepage": "https://github.com/ronan/inVRT#readme",
  "dependencies": {
    "backstopjs": "^6.3.25",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.2"
  }
}
