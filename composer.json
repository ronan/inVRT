{
    "name": "invrt/php-cli",
    "description": "An auth-enabled VRT for Drupal and Backdrop web sites and apps (PHP version)",
    "version": "1.0.1",
    "type": "application",
    "license": "MIT",
    "authors": [
        {
            "name": "Ronan Dowling"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/yaml": "^8.0",
        "symfony/console": "^8.0.7",
        "symfony/process": "^8.0",
        "symfony/config": "^8.0",
        "symfony/filesystem": "^8.0",
        "symfony/dependency-injection": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\E2E\\": "tests/e2e/",
            "Tests\\": "tests/"
        }
    },
    "bin": ["src/invrt.php"],
    "config": {
        "allow-plugins": {}
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "rector/rector": "^2.3",
        "phpstan/phpstan": "^2.1"
    }
}
