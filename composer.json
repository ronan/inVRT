{
    "name": "invrt/php-cli",
    "description": "An auth-enabled VRT for Drupal and Backdrop web sites and apps (PHP version)",
    "type": "application",
    "license": "MIT",
    "authors": [
        {
            "name": "Ronan Dowling"
        }
    ],
    "require": {
        "php": ">=7.4",
        "symfony/yaml": "^5.4|^6.0",
        "symfony/console": "^5.4|^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": ["src/invrt.php"]
}
